<h1><%= gem_pulse_config.title %></h1>

<div class="gp-summary-cards">
  <div class="gp-card">
    <span class="gp-card-value"><%= @summary[:total] %></span>
    <span class="gp-card-label">Total Gems</span>
  </div>
  <div class="gp-card">
    <span class="gp-card-value"><%= @summary[:with_cves] %></span>
    <span class="gp-card-label">With CVEs</span>
  </div>
  <div class="gp-card">
    <span class="gp-card-value"><%= @summary[:outdated] %></span>
    <span class="gp-card-label">Outdated</span>
  </div>
  <div class="gp-card">
    <span class="gp-card-value"><%= @summary[:aggregate_score] || "—" %></span>
    <span class="gp-card-label">Aggregate Score</span>
  </div>
</div>

<%# ── Dependency graph stats ── %>
<h2>Dependency Structure</h2>
<div class="gp-summary-cards">
  <div class="gp-card">
    <span class="gp-card-value"><%= @graph_stats[:direct] %></span>
    <span class="gp-card-label">Direct Deps</span>
  </div>
  <div class="gp-card">
    <span class="gp-card-value"><%= @graph_stats[:transitive] %></span>
    <span class="gp-card-label">Transitive</span>
  </div>
  <div class="gp-card">
    <span class="gp-card-value"><%= @graph_stats[:max_depth] %></span>
    <span class="gp-card-label">Max Depth</span>
  </div>
  <div class="gp-card gp-card-detail">
    <span class="gp-card-value-sm"><%= @graph_stats[:heaviest_name] %></span>
    <span class="gp-card-label">Heaviest <span class="gp-card-detail-num">(<%= @graph_stats[:heaviest_count] %> transitive deps)</span></span>
  </div>
</div>

<p class="gp-graph-link"><%= link_to "View interactive dependency graph →", graph_path %></p>

<%# ── Category breakdown ── %>
<h2>Gem Categories</h2>
<div class="gp-category-bars">
  <% max_count = @category_summary.values.max || 1 %>
  <% @category_summary.each do |category, count| %>
    <div class="gp-category-row">
      <span class="gp-category-label"><%= link_to category, gems_path(category: category) %></span>
      <div class="gp-category-bar-track">
        <div class="gp-category-bar-fill" style="width: <%= (count.to_f / max_count * 100).round %>%"></div>
      </div>
      <span class="gp-category-count"><%= count %></span>
    </div>
  <% end %>
</div>

<%# ── Needs attention ── %>
<h2>Needs Attention</h2>
<table class="gp-table">
  <thead>
    <tr>
      <th>Gem</th>
      <th>Locked</th>
      <th>Latest</th>
      <th>Status</th>
      <th>Score</th>
    </tr>
  </thead>
  <tbody>
    <% @gems.reject { |g| g[:status] == "unknown" }.sort_by { |g| g[:score] || 0 }.first(10).each do |gem| %>
      <tr>
        <td><%= link_to gem[:name], gem_path(gem[:name]) %></td>
        <td><code><%= gem[:locked_version] %></code></td>
        <td><code><%= gem[:latest_version] || "—" %></code></td>
        <td><span class="gp-badge gp-badge-<%= gem[:status] %>"><%= gem[:status] %></span></td>
        <td><%= gem[:score] || "—" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
